APP_ENV=local
APP_DEBUG=true
APP_URL=http://localhost:8080
APP_KEY=base64:replace-with-generated-key

DB_DATABASE=laravel
DB_USERNAME=laravel
DB_PASSWORD=local-change-me
DB_ROOT_PASSWORD=local-root-change-me

CACHE_STORE=redis
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis

LOG_CHANNEL=stderr
LOG_LEVEL=debug
APP_IMAGE_TAG=local
L5_SWAGGER_GENERATE_ALWAYS=false
L5_SWAGGER_CONST_HOST=http://localhost:8080
L5_SWAGGER_BASE_PATH=/api
L5_SWAGGER_UI_DARK_MODE=true
