APP_ENV=production
APP_DEBUG=false
APP_URL=https://example.com
APP_KEY=base64:replace-with-generated-key

DB_DATABASE=laravel
DB_USERNAME=laravel
DB_PASSWORD=prod-change-me
DB_ROOT_PASSWORD=prod-root-change-me

CACHE_STORE=redis
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis

LOG_CHANNEL=stderr
LOG_LEVEL=warning
APP_IMAGE_TAG=prod
L5_SWAGGER_GENERATE_ALWAYS=false
L5_SWAGGER_CONST_HOST=https://api.example.com
L5_SWAGGER_BASE_PATH=/api
L5_SWAGGER_UI_DARK_MODE=false
